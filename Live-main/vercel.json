{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    },
    {
      "src": "unpackage/dist/build/h5/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "src": "/ws",
      "dest": "server.js",
      "methods": ["GET"]
    },
    {
      "src": "/admin/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/live/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/unpackage/dist/build/h5/$1",
      "headers": {
        "Cache-Control": "s-maxage=3600, stale-while-revalidate"
      }
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "PORT": "8080",
    "VERCEL": "true"
  },
  "buildCommand": "npm ci && npm run build:h5",
  "installCommand": "npm ci",
  "outputDirectory": "unpackage/dist/build/h5"
}
