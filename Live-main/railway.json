{
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm ci && npm run build:h5",
    "watchPaths": ["package.json", "package-lock.json"]
  },
  "deploy": {
    "startCommand": "node server.js",
    "healthcheckPath": "/api/votes",
    "ports": [
      {
        "port": 8080,
        "http": true
      }
    ]
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "PORT": "8080"
      }
    }
  }
}