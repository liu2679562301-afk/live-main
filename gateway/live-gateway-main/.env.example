# 直播辩论系统网关环境变量配置模板
# 将此文件复制为 .env 并填写实际值
# 或在 Railway 控制台中配置

# ====================
# 基础配置
# ====================

# 运行端口
PORT=3000

# 环境
NODE_ENV=production

# ====================
# 后端服务配置
# ====================

# 后端API地址（重要：部署后必须修改）
# 本地开发: http://localhost:8081
# Railway部署: https://your-backend.up.railway.app
BACKEND_URL=http://localhost:8081

# WebSocket地址（通常与BACKEND_URL相同）
# WS_BACKEND_URL=ws://localhost:8081

# ====================
# 跨域配置
# ====================

# 允许的跨域来源
CORS_ORIGIN=*

# ====================
# 日志配置
# ====================

# 日志级别: error, warn, info, debug
LOG_LEVEL=info

# ====================
# 超时配置
# ====================

# 请求超时时间（毫秒）
TIMEOUT=30000

# ====================
# 缓存配置
# ====================

# 响应缓存时间（秒）
CACHE_MAX_AGE=3600
