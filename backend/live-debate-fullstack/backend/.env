# 直播辩论系统后端环境变量配置模板
# 将此文件复制为 .env 并填写实际值
# 或在 Railway 控制台中配置

# ====================
# 应用基础配置
# ====================

# 运行端口（Railway会自动设置PORT变量）
PORT=8080

# Spring 配置
SPRING_PROFILES_ACTIVE=prod

# 日志级别
LOG_LEVEL=INFO

# ====================
# 跨域配置
# ====================

# 允许的跨域来源（重要：必须包含你的前端地址）
# 多个地址用逗号分隔，例如：https://your-app.vercel.app,https://localhost:3000
CORS_ALLOWED_ORIGINS=*

# ====================
# MinIO 对象存储配置
# ====================

# MinIO 服务器地址
# 本地开发: http://localhost:9000
# Railway部署: 使用Railway插件或外部MinIO服务
MINIO_ENDPOINT=http://localhost:9000

# MinIO 访问凭证
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123

# MinIO 存储桶配置
MINIO_BUCKET=recordings
MINIO_REGION=us-east-1
MINIO_SECURE=false

# ====================
# 功能开关
# ====================

# 是否启用模拟数据
MOCK_ENABLED=true

# 是否启用WebSocket
WEBSOCKET_ENABLED=true

# 是否启用本地存储
STORAGE_ENABLED=true

# ====================
# 数据库配置（可选）
# ====================

# 如果使用 Railway PostgreSQL 插件，这些变量会自动注入
# SPRING_DATASOURCE_URL=${{Postgres.DATABASE_URL}}
# SPRING_DATASOURCE_USERNAME=${{Postgres.DATABASE_USER}}
# SPRING_DATASOURCE_PASSWORD=${{Postgres.DATABASE_PASSWORD}}

# ====================
# 其他配置
# ====================

# API基础路径（通常不需要修改）
API_BASE_PATH=/api

# WebSocket端点
WEBSOCKET_ENDPOINT=/ws-native
